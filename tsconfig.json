{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "Node",
        "lib": ["ES2022"],
        "types": ["node", "@playwright/test"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true
    },
    "include": ["src", "tests", "playwright.config.ts"],
    "exclude": ["node_modules"]
}
