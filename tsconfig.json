{
    "compilerOptions": {
      "target": "ES2020",                        // Modern JS output for Node
      "module": "CommonJS",                      // Node.js module system
      "lib": ["ES2020", "DOM"],                  // JS features + DOM types (for fetch/faker etc.)
      "moduleResolution": "node",
      "esModuleInterop": true,                   // Allows default imports from CommonJS modules
      "forceConsistentCasingInFileNames": true, // Prevents case-sensitive import errors
      "strict": true,                            // Enables strict type checking
      "noImplicitAny": true,                     // Catch missing types
      "noImplicitThis": true,
      "strictNullChecks": true,
      "skipLibCheck": true,                      // Skip type checking of dependencies
      "resolveJsonModule": true,                 // Allows importing JSON as modules
      "isolatedModules": true,                   // Needed for certain transpilers
      "outDir": "dist",                          // Optional: compiled JS output
      "types": ["node", "playwright"],           // Include Node and Playwright types
      "baseUrl": ".",                             // Base path for module resolution
      "paths": {                                  // Optional aliases
        "@apis/*": ["src/apis/*"],
        "@builders/*": ["src/builders/*"],
        "@fixtures/*": ["src/fixtures/*"],
        "@tests/*": ["tests/*"]
      }
    },
    "include": ["src/**/*.ts", "tests/**/*.ts"],
    "exclude": ["node_modules", "dist"]
  }
  