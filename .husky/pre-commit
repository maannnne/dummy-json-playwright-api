# TYPESCRIPT CHECKS
echo "🔍 Running TypeScript checks..."
npx tsc --noEmit

if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found! Please fix them before committing."
  exit 1
fi

echo "✅ TypeScript checks passed!"

# PRETTIER CHECKS
echo "🎨 Running Prettier checks..."
npx lint-staged

if [ $? -ne 0 ]; then
  echo "❌ Prettier errors found! Please fix them before committing."
  exit 1
fi

echo "✅ Prettier checks passed!"
